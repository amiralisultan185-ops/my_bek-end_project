# Application
NODE_ENV=development
PORT=3001
APP_SECRET_KEY=change-me-in-production-min-32-characters-long
APP_NAME=LexLink API
PUBLIC_APP_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# Database
DATABASE_URL=postgresql://lexlink:lexlink@127.0.0.1:55432/lexlink?schema=public

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# OTP
OTP_LENGTH=6
OTP_TTL_MINUTES=15
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_TTL_MINUTES=30
PASSWORD_RESET_TTL_MINUTES=30

# Rate Limits
RATE_LIMIT_SUBMIT_PER_HOUR=5
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=100

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@lexlink.io
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=LexLink <noreply@lexlink.io>
EMAIL_QUEUE_ENABLED=true
EMAIL_WORKER_ENABLED=true
EMAIL_JOB_MAX_ATTEMPTS=3

# S3 (Documents)
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_BUCKET_NAME=lexlink-documents
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_REGION=us-east-1
