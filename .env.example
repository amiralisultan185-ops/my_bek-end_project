# POWER LAW Digital environment template.
# Copy this file to .env for local development.
# In Docker Compose/DeployRocks, DATABASE_URL and REDIS_URL should use service names:
# postgresql://lexlink:lexlink@postgres:5432/lexlink?schema=public
# redis://redis:6379/0

# Application
ENVIRONMENT=development
NODE_ENV=development
BACKEND_PORT=3001
PORT=3001
FRONTEND_PORT=5173
# Frontend runtime API base. Leave empty for Docker Compose local proxy.
# Set to the backend public URL for split deployments such as Render.
API_BASE_URL=
APP_NAME=POWER LAW Digital API
PUBLIC_APP_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# Database
DATABASE_URL=postgresql://lexlink:lexlink@127.0.0.1:55432/lexlink?schema=public

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key-minimum-32-characters
JWT_REFRESH_SECRET_KEY=change-me-refresh-secret-key-minimum-32-chars
APP_SECRET_KEY=change-me-backward-compatible-secret-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Initial owner seed
OWNER_EMAIL=owner@example.invalid
OWNER_PASSWORD=OwnerPass123!
OWNER_NAME=POWER LAW Digital Owner

# OTP and verification codes
OTP_LENGTH=6
OTP_TTL_MINUTES=15
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_TTL_MINUTES=30
PASSWORD_RESET_TTL_MINUTES=30

# Rate limits
RATE_LIMIT_SUBMIT_PER_HOUR=5
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=100

# Email provider through SMTP
# For SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey, EMAIL_API_KEY=<sendgrid-api-key>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-smtp-password
EMAIL_API_KEY=your-email-provider-api-key
EMAIL_FROM=POWER LAW Digital <verified-sender@example.invalid>
EMAIL_FROM_ADDRESS=POWER LAW Digital <verified-sender@example.invalid>
SMTP_CHECK_TO=your-test-inbox@example.invalid
EMAIL_QUEUE_ENABLED=true
EMAIL_WORKER_ENABLED=true
EMAIL_JOB_MAX_ATTEMPTS=3

# Document encryption
# Generate a production value with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DOCUMENT_ENCRYPTION_KEY=change-me-document-encryption-key-min-32-chars
DOCUMENT_MAX_UPLOAD_BYTES=20971520
