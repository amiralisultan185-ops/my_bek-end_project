        {
          "name": "POST /users/bulk - Create all staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  const owner = json.results.find(item => item.ok && item.user.role === 'owner');",
                  "  const lawyer = json.results.find(item => item.ok && item.user.role === 'lawyer');",
                  "  if (owner) pm.collectionVariables.set('ownerId', owner.user.id);",
                  "  if (lawyer) pm.collectionVariables.set('lawyerId', lawyer.user.id);",
                  "}"
                ]
              }
            }
          ],
